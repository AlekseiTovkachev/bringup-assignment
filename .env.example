# Optional Google integrations
# Usually handled inside Make. Only needed in the app if it talks to Google APIs directly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_ENGAGEMENT_TEMPLATE_ID=
GOOGLE_DRIVE_PROJECT_FOLDER_NAME=BringUp Assignment
GOOGLE_DRIVE_PROJECT_FOLDER_ID=
GOOGLE_DRIVE_ENGAGEMENT_OUTPUT_FOLDER_ID=

