# monday.com API
# Used by the Vercel client portal and any local scripts that read/write monday data.
MONDAY_API_TOKEN=
MONDAY_API_VERSION=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_WORKSPACE_ID=
MONDAY_BOARD_KIND=public
MONDAY_BOARD_PREFIX=
MONDAY_DISPLAY_LANGUAGE=he
PORTAL_CLIENT_LOOKUP_LIMIT=100
PORTAL_TASK_LOOKUP_LIMIT=100

# monday.com board IDs
MONDAY_STAFF_BOARD_ID=
MONDAY_CLIENTS_BOARD_ID=
MONDAY_ONGOING_TASKS_BOARD_ID=

# monday.com column IDs
# Fill these after the boards are created. Column IDs are often different from display names.
MONDAY_STAFF_NAME_COLUMN_ID=
MONDAY_STAFF_ROLE_COLUMN_ID=
MONDAY_STAFF_EMAIL_COLUMN_ID=
MONDAY_STAFF_PHONE_COLUMN_ID=
MONDAY_STAFF_SPECIALTIES_COLUMN_ID=
MONDAY_STAFF_WEEKLY_CAPACITY_HOURS_COLUMN_ID=
MONDAY_STAFF_STAFF_STATUS_COLUMN_ID=
# `MONDAY_CLIENT_NAME_COLUMN_ID=name` means the Clients board uses monday's primary item-name column.
MONDAY_CLIENT_NAME_COLUMN_ID=
MONDAY_CLIENT_LEGAL_TAX_ID_COLUMN_ID=
MONDAY_CLIENT_ENTITY_TYPE_COLUMN_ID=
MONDAY_CLIENT_PRIMARY_CONTACT_NAME_COLUMN_ID=
MONDAY_CLIENT_EMAIL_COLUMN_ID=
MONDAY_CLIENT_PHONE_COLUMN_ID=
MONDAY_CLIENT_ONBOARDING_STATUS_COLUMN_ID=
MONDAY_CLIENT_ASSIGNED_ACCOUNTANT_COLUMN_ID=
MONDAY_CLIENT_SERVICE_TYPES_COLUMN_ID=
MONDAY_CLIENT_MISSING_INFORMATION_COLUMN_ID=
MONDAY_CLIENT_DOCUMENT_CHECK_COLUMN_ID=
MONDAY_CLIENT_ENGAGEMENT_LETTER_STATUS_COLUMN_ID=
MONDAY_CLIENT_ENGAGEMENT_LETTER_LINK_COLUMN_ID=
MONDAY_CLIENT_RESPONSE_COLUMN_ID=
MONDAY_CLIENT_RESPONSE_DETAILS_COLUMN_ID=
MONDAY_CLIENT_LAST_UPDATE_COLUMN_ID=
MONDAY_CLIENT_INTAKE_NOTES_COLUMN_ID=
MONDAY_CLIENT_CONSENT_CONFIRMED_COLUMN_ID=
MONDAY_CLIENT_DEMO_ASSIGNED_STAFF_COLUMN_ID=
# Optional heavier demo backlink. Leave blank in the default lightweight setup.
MONDAY_CLIENT_LINKED_ONGOING_TASKS_COLUMN_ID=
MONDAY_TASK_LINKED_CLIENT_COLUMN_ID=
# Optional mirror columns. Leave blank in the default lightweight setup.
MONDAY_TASK_CLIENT_NAME_COLUMN_ID=
MONDAY_TASK_LEGAL_TAX_ID_COLUMN_ID=
MONDAY_TASK_DEMO_OWNER_STAFF_COLUMN_ID=
MONDAY_TASK_SERVICE_TYPE_COLUMN_ID=
MONDAY_TASK_REPORTING_PERIOD_COLUMN_ID=
MONDAY_TASK_OWNER_COLUMN_ID=
MONDAY_TASK_DUE_DATE_COLUMN_ID=
MONDAY_TASK_STATUS_COLUMN_ID=
MONDAY_TASK_CLIENT_REQUEST_COLUMN_ID=
MONDAY_TASK_LAST_UPDATED_COLUMN_ID=

# Client portal
# Use demo-safe data only if the portal uses tax-ID lookup without authentication.
PORTAL_DEMO_MODE=true
PORTAL_ALLOWED_ORIGIN=http://localhost:3000

# monday.com intake form
# Generated through the Monday MCP form tools. The form tool creates a backing board.
MONDAY_INTAKE_FORM_TITLE=טופס קליטת לקוח חדש
MONDAY_INTAKE_FORM_DESCRIPTION=נא למלא את הפרטים כדי לפתוח תיק לקוח ראשוני. הצוות יחזור אליכם לאחר בדיקת המידע.
MONDAY_INTAKE_FORM_BOARD_NAME=קליטת לקוחות מהטופס
MONDAY_INTAKE_FORM_FOLDER_ID=
MONDAY_INTAKE_FORM_FOLDER_NAME=
MONDAY_INTAKE_FORM_OWNER_IDS=
MONDAY_INTAKE_FORM_SUBSCRIBER_IDS=
MONDAY_INTAKE_FORM_BOARD_ID=
MONDAY_INTAKE_FORM_TOKEN=
MONDAY_INTAKE_FORM_URL=

# Optional portal authentication
# For production, use authenticated access rather than tax-ID lookup alone.
AUTH_SECRET=
AUTH_TRUST_HOST=true
EMAIL_FROM=

# Make automations
# Engagement-letter automation uses a Make custom webhook called by monday.
MAKE_API_TOKEN=
MAKE_ZONE=us1.make.com
