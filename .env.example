MAKE_WEEKLY_REPORT_SCENARIO_ID=
MAKE_WEEKLY_REPORT_SCENARIO_NAME=BringUp - Weekly Management Report
MAKE_WEEKLY_REPORT_RECIPIENT_EMAIL=
