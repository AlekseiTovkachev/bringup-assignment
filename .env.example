AUTOMATION_MESSAGE_ENGAGEMENT_READY_TO_SEND_UPDATE=קיים קישור למכתב ההתקשרות והסטטוס הוא נוצר, לכן הסטטוס עודכן לנשלח.
AUTOMATION_MESSAGE_ENGAGEMENT_SENT_UPDATE=מייל מכתב ההתקשרות נשלח ללקוח והסטטוס עודכן לנשלח.

# Optional email provider
# Usually handled by Gmail inside Make. Only needed if the app sends email directly.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Optional AI integration
# Use only if we add AI-assisted summaries, email drafting, or document drafting.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Vercel deployment
# Not needed at runtime on Vercel. Useful only for CLI/CI deployment automation.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
