MAKE_WEEKLY_REPORT_EMAIL_SUBJECT_STATIC=דוח ניהולי שבועי
MAKE_WEEKLY_REPORT_TITLE=דוח ניהולי שבועי
MAKE_WEEKLY_REPORT_DAY=1
